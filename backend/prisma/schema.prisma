generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  role_id   Int    @id @default(autoincrement())
  role_name String @db.VarChar(50)
  users     User[]

  @@map("roles")
}

model User {
  user_id                   Int                  @id @default(autoincrement())
  role_id                   Int
  full_name                 String               @db.VarChar(100)
  email                     String               @unique @db.VarChar(100)
  password_hash             String               @db.VarChar(255)
  phone                     String?              @db.VarChar(20)
  status                    String               @default("active") @db.VarChar(20)
  created_at                DateTime             @default(now())
  updated_at                DateTime?            @updatedAt
  password_reset_code_hash  String?              @db.VarChar(255)
  password_reset_expires_at DateTime?
  email_verified_at         DateTime?
  register_otp_expires_at   DateTime?
  register_otp_hash         String?              @db.VarChar(255)
  activity_logs             ActivityLog[]
  backup_logs               BackupLog[]
  reviewed_manager_requests ManagerRoleRequest[] @relation("ManagerRoleReviewer")
  manager_requests          ManagerRoleRequest[] @relation("ManagerRoleRequester")
  meeting_minutes           MeetingMinute[]
  minute_attachments        MinuteAttachment[]
  notifications             Notification[]
  support_attachments       SupportAttachment[]
  support_messages          SupportMessage[]
  assigned_tickets          SupportTicket[]      @relation("AssignedTickets")
  handled_tickets           SupportTicket[]      @relation("HandledTickets")
  support_tickets           SupportTicket[]      @relation("RequestedSupport")
  resolved_tickets          SupportTicket[]      @relation("ResolvedTickets")
  role                      Role                 @relation(fields: [role_id], references: [role_id])

  @@map("users")
}

model MinuteType {
  type_id         Int             @id @default(autoincrement())
  type_name       String          @db.VarChar(100)
  meeting_minutes MeetingMinute[]

  @@map("minute_types")
}

model MeetingMinute {
  minute_id          Int                 @id @default(autoincrement())
  minute_code        String              @unique @db.VarChar(50)
  type_id            Int
  created_by         Int
  title              String              @db.VarChar(255)
  class_name         String              @db.VarChar(100)
  meeting_date       DateTime            @db.Date
  start_time         DateTime            @db.Time(6)
  end_time           DateTime            @db.Time(6)
  location           String?             @db.VarChar(255)
  meeting_form       String?             @db.VarChar(50)
  host_name          String?             @db.VarChar(100)
  secretary_name     String?             @db.VarChar(100)
  attendee_summary   String?
  absentee_summary   String?
  purpose            String?
  discussion_content String
  conclusion_content String?
  followup_summary   String?
  status             String              @default("draft") @db.VarChar(20)
  created_at         DateTime            @default(now())
  updated_at         DateTime?           @updatedAt
  is_public          Boolean             @default(false)
  published_at       DateTime?
  reviewed_by        Int?
  reviewed_at        DateTime?
  review_note        String?
  template_data      Json?
  creator            User                @relation(fields: [created_by], references: [user_id])
  minute_type        MinuteType          @relation(fields: [type_id], references: [type_id])
  attachments        MinuteAttachment[]
  participants       MinuteParticipant[]
  tasks              MinuteTask[]

  @@map("meeting_minutes")
}

model MinuteTask {
  task_id      Int           @id @default(autoincrement())
  minute_id    Int
  task_content String
  assigned_to  String?       @db.VarChar(100)
  deadline     DateTime?     @db.Date
  task_status  String        @default("pending") @db.VarChar(20)
  minute       MeetingMinute @relation(fields: [minute_id], references: [minute_id], onDelete: Cascade)

  @@map("minute_tasks")
}

model MinuteParticipant {
  participant_id    Int           @id @default(autoincrement())
  minute_id         Int
  full_name         String        @db.VarChar(100)
  role_in_meeting   String?       @db.VarChar(100)
  attendance_status String        @default("present") @db.VarChar(30)
  minute            MeetingMinute @relation(fields: [minute_id], references: [minute_id], onDelete: Cascade)

  @@map("minute_participants")
}

model MinuteAttachment {
  attachment_id      Int           @id @default(autoincrement())
  minute_id          Int
  uploaded_by        Int
  file_name          String        @db.VarChar(255)
  file_path          String        @db.VarChar(255)
  file_type          String?       @db.VarChar(50)
  uploaded_at        DateTime      @default(now())
  is_public_safe     Boolean       @default(false)
  public_scan_status String        @default("pending") @db.VarChar(30)
  minute             MeetingMinute @relation(fields: [minute_id], references: [minute_id], onDelete: Cascade)
  uploader           User          @relation(fields: [uploaded_by], references: [user_id])

  @@map("minute_attachments")
}

model ActivityLog {
  log_id        Int      @id @default(autoincrement())
  user_id       Int
  action_name   String   @db.VarChar(100)
  target_table  String?  @db.VarChar(100)
  target_id     Int?
  action_detail String?
  created_at    DateTime @default(now())
  user          User     @relation(fields: [user_id], references: [user_id])

  @@map("activity_logs")
}

model BackupLog {
  backup_id     Int      @id @default(autoincrement())
  performed_by  Int
  action_type   String   @db.VarChar(20)
  type          String?  @db.VarChar(20)
  status        String   @default("PENDING") @db.VarChar(20)
  started_at    DateTime?
  completed_at  DateTime?
  file_name     String?  @db.VarChar(255)
  file_path     String?  @db.VarChar(255)
  file_size     Int?
  error_message String?
  triggered_by  String?  @db.VarChar(50)
  created_at    DateTime @default(now())
  performer     User     @relation(fields: [performed_by], references: [user_id])

  @@map("backup_logs")
}

model SupportTicket {
  ticket_id       Int              @id @default(autoincrement()) @map("request_id")
  requested_by    Int?
  title           String           @db.VarChar(255)
  content         String
  status          String           @default("PENDING") @db.VarChar(20)
  response        String?
  handled_by      Int?
  created_at      DateTime         @default(now())
  updated_at      DateTime?        @updatedAt
  category        String?          @db.VarChar(100)
  resolution      String?
  assigned_admin  Int?
  resolved_by     Int?
  resolved_at     DateTime?
  last_message_at DateTime?
  messages        SupportMessage[]
  assignee        User?            @relation("AssignedTickets", fields: [assigned_admin], references: [user_id])
  handler         User?            @relation("HandledTickets", fields: [handled_by], references: [user_id])
  requester       User?            @relation("RequestedSupport", fields: [requested_by], references: [user_id])
  resolver        User?            @relation("ResolvedTickets", fields: [resolved_by], references: [user_id])

  @@map("support_requests")
}

model SupportMessage {
  message_id  Int                 @id @default(autoincrement())
  ticket_id   Int
  sender_id   Int
  sender_type String              @db.VarChar(10)
  content     String
  created_at  DateTime            @default(now())
  attachments SupportAttachment[]
  sender      User                @relation(fields: [sender_id], references: [user_id])
  ticket      SupportTicket       @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade)

  @@map("support_messages")
}

model SupportAttachment {
  attachment_id Int            @id @default(autoincrement())
  message_id    Int
  file_name     String         @db.VarChar(255)
  file_path     String         @db.VarChar(255)
  file_type     String?        @db.VarChar(50)
  file_size     Int?
  uploaded_by   Int?
  created_at    DateTime       @default(now())
  message       SupportMessage @relation(fields: [message_id], references: [message_id], onDelete: Cascade)
  uploader      User?          @relation(fields: [uploaded_by], references: [user_id])

  @@map("support_attachments")
}

model ManagerRoleRequest {
  request_id  Int       @id @default(autoincrement())
  user_id     Int
  reason      String?
  status      String    @default("pending") @db.VarChar(20)
  response    String?
  reviewed_by Int?
  created_at  DateTime  @default(now())
  updated_at  DateTime? @updatedAt
  reviewer    User?     @relation("ManagerRoleReviewer", fields: [reviewed_by], references: [user_id])
  user        User      @relation("ManagerRoleRequester", fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("manager_role_requests")
}

model Notification {
  notification_id Int       @id @default(autoincrement())
  user_id         Int
  title           String    @db.VarChar(150)
  message         String
  type            String    @default("info") @db.VarChar(30)
  target_table    String?   @db.VarChar(100)
  target_id       Int?
  is_read         Boolean   @default(false)
  created_at      DateTime  @default(now())
  read_at         DateTime?
  user            User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id, is_read, created_at])
  @@map("notifications")
}
